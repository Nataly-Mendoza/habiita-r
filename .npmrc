# Habitta React — pnpm / npm security configuration
# Read by both npm and pnpm.

# Hoist all packages to node_modules root (npm-compatible behavior).
# Required for Vite 8 / rolldown to resolve transitive dependencies correctly.
shamefully-hoist=true

# Fail install if any dependency has a vulnerability at this level or higher.
audit-level=high

# Disable funding messages (keeps output clean)
fund=false

# pnpm: resolve peer dependencies automatically
auto-install-peers=true

# pnpm: prevent install when peer conflicts exist (safer default)
strict-peer-dependencies=false

# Reproducible builds: exact version pinning for new deps
save-exact=true
